# tsurispot 環境変数テンプレート
# このファイルをコピーして `.env.local` を作成し、本番値を設定する。
# `.env.local` は git 管理外。値の管理は本番（GitHub Actions Secrets / App Runner 環境変数）と整合させること。

# ===== microCMS（ブログCMS） =====
# 欠落時はブログのCMS記事が空になり、静的記事のみ表示される（fail-safe）
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# ===== AWS / S3 =====
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
S3_REGION=
S3_BUCKET=

# ===== Stripe（課金） =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_COUPON_BASIC=
STRIPE_COUPON_PRO=

# ===== LINE =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ===== Meta / Instagram =====
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ===== Google Apps Script（釣果報告） =====
GAS_CATCH_REPORT_URL=

# ===== 管理画面 =====
ADMIN_SECRET=

# ===== 公開系（NEXT_PUBLIC_ はクライアントバンドルに含まれる） =====
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADSENSE_ID=
# 広告スロットID（任意・未設定時は既存スロットにフォールバックするため空でも動作する）
# GA4(PR#85)で稼ぐ枠が判明したら、その枠だけ AdSense で専用ユニットを発行して設定する
NEXT_PUBLIC_AD_SLOT_IN_ARTICLE=
NEXT_PUBLIC_AD_SLOT_DISPLAY=
NEXT_PUBLIC_AD_SLOT_NATIVE_BREAK=
NEXT_PUBLIC_AD_SLOT_MULTIPLEX=
NEXT_PUBLIC_AD_SLOT_PRE_FOOTER=
NEXT_PUBLIC_AD_SLOT_SIDEBAR=
NEXT_PUBLIC_AD_SLOT_SIDEBAR_STICKY=
NEXT_PUBLIC_AD_SLOT_HEADER_BANNER=
NEXT_PUBLIC_AD_SLOT_SIDE_RAIL=
NEXT_PUBLIC_AD_SLOT_IN_FEED=
NEXT_PUBLIC_AD_SLOT_PARALLEL=
NEXT_PUBLIC_AD_SLOT_MOBILE_STICKY=
NEXT_PUBLIC_AD_SLOT_MOBILE_HEADER_BANNER=
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ===== 開発フラグ =====
# ANALYZE=true で `npm run analyze` 時にバンドル解析を有効化
ANALYZE=
