# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# 自己改善エージェント（環境固有・秘密・実行時状態は追跡しない。テンプレートは config/agent.config.example.json）
/secrets/
/logs/agent/
/config/agent.config.json
/.claude/state/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# テンプレートは共有する（秘密情報なし・新規開発者が必要な env を把握できる）
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# Patent pipeline cache
patent/data/cache/

# Twitter投稿データキャッシュ
scripts/twitter/.cache/
scripts/twitter/.posted-*.json

# Claude Code
.agents/
.claude/
# 例外: spot-generator skill だけは repo 管理（再現性のため）。
# git add -f で強制追跡しているので gitignore は触らない。
# checkpoint state (.claude/state/spot-generation-progress.json) はマシン固有なので追跡しない。
skills-lock.json
scripts/instagram/node_modules/

# Capacitor (iOS / Android のネイティブ project は再生成可能)
/ios/
/android/
.audit-cache/
.spots-bulk-cache/
